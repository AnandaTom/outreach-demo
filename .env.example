# Outreach Demo - Environment Variables
# Copy this file to .env and fill in your keys

# Apify - lead scraping (apify.com)
APIFY_API_KEY=your_apify_key_here

# Anthropic - AI icebreaker + email generation (console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Sheets - save leads for review
# 1. Go to console.cloud.google.com
# 2. Enable Google Sheets API + Google Drive API
# 3. Create a Service Account, download JSON key
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# Optional: email to auto-share the created sheet with
SHARE_EMAIL=your@email.com

# Instantly - email sending (app.instantly.ai/settings/api)
INSTANTLY_API_KEY=your_instantly_key_here
